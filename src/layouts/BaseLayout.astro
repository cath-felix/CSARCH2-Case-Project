---
// src/layouts/BaseLayout.astro
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Texture Filtering Exhibit</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <h1>🎮 Computer Architecture Virtual Exhibit</h1>
        <p class="subtitle">S40 - Texture Filtering in 3D Graphics</p>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>Computer Architecture is Forever | Virtual Museum Exhibit 2026</p>
      </footer>
    </div>
  </body>
</html>